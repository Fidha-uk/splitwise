# ── Copy this file to .env and fill in your values ──────────
# NEVER commit the real .env to git

# Flask environment: development | production
FLASK_ENV=production

# REQUIRED in production: generate with `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

# Database path (SQLite). Use absolute path on server.
# DATABASE=/var/www/splitwise/instance/splitwise.db

# Upload folder for bill images
# UPLOAD_FOLDER=/var/www/splitwise/uploads

# Set to true when running behind HTTPS (enables secure cookies)
HTTPS=false

# Server port (Gunicorn also accepts -b flag)
PORT=5000
